# =========================================
# Local dev → copia a .env.local
# Producción → copia a .env.production en el servidor (NUNCA commitear)
# =========================================

# Site URL — usada por metadataBase para que las OG images sean URLs absolutas.
# Dev:  http://localhost:3000
# Prod: https://arianeygiuseppe.enigmasac.com
NEXT_PUBLIC_SITE_URL=https://arianeygiuseppe.enigmasac.com

# Google Analytics. Si lo dejas vacío, GA no se carga.
NEXT_PUBLIC_GA_ID=G-MLX7ZPK5MK

# Database — Neon Postgres (sign up en neon.tech).
# Sin esto, el form RSVP devuelve ok y solo loguea en consola (no persiste).
DATABASE_URL=postgres://USER:PASS@HOST/dbname?sslmode=require

# Admin panel — protege /admin
#   ADMIN_PASSWORD: la que tecleas al entrar
#   ADMIN_SECRET:   string aleatorio largo (firma la cookie de sesión)
#                   generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=cambiame
ADMIN_SECRET=cambia-esto-por-32-bytes-aleatorios
