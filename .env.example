# Database — Neon Postgres (sign up at neon.tech)
# Copy your connection string from Neon dashboard. Until set, the form returns ok
# and logs payloads to the dev console.
DATABASE_URL=postgres://USER:PASS@HOST/dbname?sslmode=require

# Admin panel — protects /admin
# - ADMIN_PASSWORD: whatever you'll type at /admin/login
# - ADMIN_SECRET: any long random string (used to sign the session cookie)
ADMIN_PASSWORD=cambiame
ADMIN_SECRET=cambia-esto-por-32-bytes-aleatorios
